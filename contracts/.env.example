# ── Required ──
# Deployer key (testnet only — never a mainnet key in plaintext)
PRIVATE_KEY=0x...

# ── Required (all are brief §10 open questions — no defaults on purpose) ──
# Protocol multisig: admin + treasury until final governance is decided (§10.5)
PROTOCOL_MULTISIG=0x...
# Canonical Uniswap-v2 style deployment on Robinhood Chain (§10.2)
DEX_FACTORY=0x...
DEX_ROUTER=0x...
WETH=0x...

# Robinhood Chain testnet RPC (§10.9)
RPC_URL=https://...

# ── Optional (defaults match the brief at ETH/USD = 3850) ──
# VIRTUAL_ETH=1122000000000000000        # 1.122 ETH → starting mcap ≈ $4,000
# VIRTUAL_TOKEN=1080000000000000000000000000  # 1.08e9 tokens (80M virtual buffer)
# GRADUATION_ETH=2600000000000000000     # 2.6 ETH → graduation mcap ≈ $44,000
# DEPLOY_FEE=2000000000000000            # 0.002 ETH (§10.8)
# DEPLOY_ROBIN=false                     # M2 — blocked on $ROBIN tokenomics (§10.1)
# ROBIN_SUPPLY=1000000000000000000000000000   # 1B placeholder (§10.1)
