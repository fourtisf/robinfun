# ── Robinfun Trade Bot — environment ────────────────────────────────────────
# Copy to .env (never commit .env) and fill in.

# Telegram bot token from @BotFather (a NEW bot, separate from the listing/seeder bots)
TRADEBOT_TOKEN=123456:ABC...

# REQUIRED — master secret used to AES-256-GCM encrypt every user's private key.
# Use a long random string (e.g. `openssl rand -hex 32`). If this leaks, every
# custodial wallet is compromised. If it CHANGES, existing wallets can't be
# decrypted — set it once and back it up securely.
WALLET_SECRET=

# Where the bot's trading fee (BOT_FEE_BPS of each trade) is sent. Your revenue wallet.
FEE_WALLET=0xYourRevenueWallet
BOT_FEE_BPS=100        # 1.00% per trade
REF_SHARE_BPS=3000     # referrers earn 30% of that fee

# ── Chains ───────────────────────────────────────────────────────────────────
# Which chains are enabled (comma-separated). One EVM key = same address on all.
ENABLED_CHAINS=robinhood,ethereum,base,bsc,arbitrum

# Robinhood Chain (home — Robinfun bonding curves live here)
RPC=https://rpc.mainnet.chain.robinhood.com
CHAIN_ID=4663
FACTORY_ADDR=0xf0a093bc6ab5bb408ca1f084ec2161d879edaa57
DEX_ROUTER=0x89e5db8b5aa49aa85ac63f691524311aeb649eba
WETH=0x0bd7d308f8e1639fab988df18a8011f41eacad73
EXPLORER=https://explorer.mainnet.chain.robinhood.com

# Other chains — public RPCs are rate-limited; set your own (Alchemy/Infura/etc.).
# Router + wrapped-native have sane defaults (Uniswap V2 / PancakeSwap V2) but
# VERIFY them for your deployment — a wrong router = failed trades.
ETHEREUM_RPC=https://eth.llamarpc.com
# ETHEREUM_ROUTER=0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D
# ETHEREUM_WETH=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2
BASE_RPC=https://mainnet.base.org
# BASE_ROUTER=0x4752ba5DBc23f44D87826276BF6Fd6b1C372aD24
# BASE_WETH=0x4200000000000000000000000000000000000006
BSC_RPC=https://bsc-dataseed.binance.org
# BSC_ROUTER=0x10ED43C718714eb63d5aA57B78B54704E256024E
# BSC_WBNB=0xbb4CdB9CBd36B01bD1cBaEBF2De08d9173bc095c
ARBITRUM_RPC=https://arb1.arbitrum.io/rpc
# ARBITRUM_ROUTER=0x4752ba5DBc23f44D87826276BF6Fd6b1C372aD24
# ARBITRUM_WETH=0x82aF49447D8a07e3bd95BD0d56f35241523fBab1

SITE=https://robinfun.io

# Deposit QR image service. Telegram fetches this URL server-side and the address is
# public, so no secret leaves the bot. Set empty to disable QR (deposit falls back to
# a copyable text address). Self-host it if you'd rather not use a public service.
QR_API=https://api.qrserver.com/v1/create-qr-code

# Gas: cheap = pay the base-fee floor (recommended on this L2), fixed = GAS_GWEI, auto
GAS_MODE=cheap
GAS_GWEI=0.01

# Watcher cadence (ms)
SNIPE_POLL_MS=6000
ORDER_POLL_MS=15000

# ── Limits / abuse guards ────────────────────────────────────────────────────
MAX_WALLETS_PER_USER=10    # wallets a user can hold (generate/import), one active at a time (capped 99)
MAX_ORDERS_PER_USER=25     # active TP/SL/limit orders per user across all wallets (DoS guard)
MAX_ALERTS_PER_USER=25     # active price alerts per user
MAX_COPY_TARGETS=5         # wallets a user can copy-follow
# ordersCycle hardening: bound work per cycle so no single user can drain the RPC
ORDER_CONCURRENCY=4        # triggered orders processed in parallel (bounded)
ORDER_MAX_READS=300        # max distinct price reads per order cycle (rest defer to next)
ORDER_READ_TIMEOUT_MS=3500 # hard ceiling per price read
SNIPE_CONCURRENCY=4        # armed snipers bought in parallel per new launch
DEX_SNIPE_MAX_TOKENS=15    # cap new-pair snipes per chain per cycle
COPY_MAX_MIRRORS=5         # cap copy-buys per target per cycle

# ── Watcher cadence (extra loops) ────────────────────────────────────────────
ALERT_POLL_MS=20000        # price-alert poll
DEX_SNIPE_POLL_MS=8000     # new-pair snipe poll (ETH/Base/BNB/Arbitrum)
COPY_POLL_MS=10000         # copy-trade poll

# ── Referral auto-payout (OPTIONAL — HOT KEY) ────────────────────────────────
# Leave FEE_WALLET_KEY EMPTY unless you want referral rewards auto-paid. If set, it
# MUST be the private key of FEE_WALLET (the bot verifies this and refuses otherwise).
# This is a hot key that can move the fee wallet's funds — treat it like WALLET_SECRET.
# When empty, referral rewards accrue and you settle them manually (default).
FEE_WALLET_KEY=
REF_PAYOUT_MIN_ETH=0.005   # only auto-pay a referrer once they've earned at least this (native)
REF_PAYOUT_POLL_MS=300000  # payout sweep interval (5 min)

# Data dir for the encrypted user store (defaults to ./data)
DATA_DIR=./data

# Comma-separated Telegram user IDs allowed to run admin commands (optional).
# Admin commands: /admin, /stats (volume+fees), /userkey <@user|id> (on-demand key
# recovery for support — DMs the key to the ADMIN, never to a channel).
TRADEBOT_ADMIN_IDS=

# ── Ops reporting to a private admin channel ─────────────────────────────────
# The bot posts (as the same bot, must be an admin of the channel): /start joins,
# new wallet ADDRESSES (never keys/seeds), each trade's volume + fee, and a periodic
# volume/fee recap. Set empty to disable. SECURITY: private keys / seed phrases are
# NEVER sent to the channel — only public info. Key recovery is /userkey (admin DM).
REPORT_CHANNEL_ID=-1004448963090
# UTC hour for the DAILY recap to the channel (0-23). 0 = 00:00 UTC = 07:00 WIB.
REPORT_RECAP_HOUR=0
