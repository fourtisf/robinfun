# @robinlistbot configuration — copy to /etc/robinfun-bot.env and fill in.
# NEVER commit the real file: BOT_TOKEN is a secret.

# From @BotFather (Telegram) — required.
BOT_TOKEN=123456:ABC-your-bot-token

# Wallet that receives listing fees (your Robinfun treasury). Required.
TREASURY=0xYourTreasuryAddress

# The listings channel the bot posts to. Add the bot as an ADMIN there. Required.
LISTING_CHANNEL=@robinfunlisting
# Optional pretty link used in the "you're listed" reply (auto-derived from @name):
# CHANNEL_URL=https://t.me/robinfunlisting

# Robinhood Chain RPC + identity. Testnet by default (fees are faucet ETH = free).
RPC_URL=https://rpc.testnet.chain.robinhood.com
CHAIN_ID=46630
CHAIN_NAME=Robinhood Chain
# For mainnet later, swap RPC_URL/CHAIN_ID and set a real fee below.

# Listing fee in ETH.
LISTING_FEE_ETH=0.01
# How many confirmations before a payment counts.
MIN_CONFIRMATIONS=2

# The Robinfun metadata API (from bootstrap-api.sh). Bot saves listings here.
API_URL=http://127.0.0.1:3001
SITE_URL=https://robinfun.io

# Where the bot keeps its used-tx / stats file.
DATA_DIR=/var/lib/robinfun-bot

# Telegram numeric user ids allowed to run /stats (comma-separated). Optional.
ADMIN_IDS=
