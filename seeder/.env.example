# Robinfun seeder — OPTIONAL config. Copy to .env only if you want to change
# defaults:  cp .env.example .env  &&  nano .env    (.env is git-ignored)
#
# ⭐ ZERO private-key setup. The bot GENERATES its own 5 deployer wallets and
#    prints their addresses. YOUR ONLY JOB: send ETH to those addresses.
#    Just run:  node index.js   — no key required.

# --- everything below is optional (these are the defaults) ---
NUM_WALLETS=5            # how many deployer wallets the bot generates (1–20)
DEV_BUY_ETH=0.001        # ETH each launch buys of its own token
CREATOR_LEVY_BPS=100     # creator fee bps, buy+sell (100 = 1%, max 1000 = 10%)
INTERVAL_SECONDS=60      # seconds between launches
# MAX_TOKENS=0           # optional cap (0 = keep going until wallets run dry)
# FACTORY_ADDR=0xfa5c740aec9d91cebdc9844e5ca6591f309a5dd2
# BACKEND=http://127.0.0.1:3001
# DRY_RUN=1              # generate + print wallets, spend nothing

# --- Telegram control bot (only needed for  node telegram.js) ---
# Token from @BotFather. If it ever leaks, /revoke in BotFather + regenerate.
TELEGRAM_TOKEN=
# Optional: lock the bot to specific numeric chat IDs (comma-separated).
# Leave BLANK and the FIRST person who messages the bot auto-becomes admin.
TELEGRAM_ADMIN_IDS=

# --- OPTIONAL convenience only — leave BLANK for the zero-key flow ---
# If you set FUNDER_KEY to the OWNER wallet, the bot will ADDITIONALLY
# auto-allow-list and auto-fund the generated deployers for you. Not required.
# FUNDER_KEY=
# BUDGET_CAP_ETH=0.05    # funder mode only: hard cap on ETH the funder sends out
# FUND_PER_WALLET_ETH=   # funder mode only: ETH per deployer (default budget/N)
