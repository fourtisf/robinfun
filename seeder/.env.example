# Robinfun seeder — copy this to  .env  and fill in your funder key ONCE.
#   cp .env.example .env   &&   nano .env
# After that just run:  node index.js   (or the pm2 bootstrap) — fully automatic.
# NOTE: .env is git-ignored. NEVER commit or screenshot your real key.

# The ONE thing that can't be auto-generated: a wallet WITH ETH (the fuel).
# Must be the allow-listed OWNER wallet (it funds + allow-lists the deployers).
FUNDER_KEY=0xYOUR_OWNER_PRIVATE_KEY_64_HEX

# Everything below is optional (these are the defaults).
NUM_WALLETS=5
DEV_BUY_ETH=0.001
CREATOR_LEVY_BPS=100
BUDGET_CAP_ETH=0.05
INTERVAL_SECONDS=60
# FACTORY_ADDR=0xfa5c740aec9d91cebdc9844e5ca6591f309a5dd2
# BACKEND=http://127.0.0.1:3001
# DRY_RUN=1
